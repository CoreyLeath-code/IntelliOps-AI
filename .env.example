# IntelliOps AI — Environment Variables
# Copy this file to .env and fill in your values before running locally.
# Never commit a real .env file to version control.

# ----- Go Prediction API -----
# URL of the ML model service used by the Go API to forward prediction requests.
MODEL_SERVICE_URL=http://ml-model:8001/predict

# ----- Python ML Model Service -----
# MLflow run ID used to load the trained model.
# Set this to the run ID produced by train.py when using the root app.py.
MLFLOW_RUN_ID=<your-mlflow-run-id>

# ----- Streamlit Dashboard -----
# Base URL of the Go prediction API exposed to the Streamlit frontend.
API_URL=http://localhost:8080
